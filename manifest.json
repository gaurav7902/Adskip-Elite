{
  "manifest_version": 3,
  "name": "AdSkip Elite",
  "version": "1.0",

  "permissions": ["storage", "notifications"],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
